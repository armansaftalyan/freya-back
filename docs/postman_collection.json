{
  "info": {
    "name": "Beauty Salon API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]},
        "body": {"mode": "raw", "raw": "{\n  \"name\": \"Client\",\n  \"email\": \"new@example.com\",\n  \"password\": \"password123\"\n}"}
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]},
        "body": {"mode": "raw", "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"password\"\n}"}
      }
    },
    {
      "name": "Catalog Categories",
      "request": {
        "method": "GET",
        "url": {"raw": "{{base_url}}/api/categories", "host": ["{{base_url}}"], "path": ["api", "categories"]}
      }
    },
    {
      "name": "Get Slots",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/slots?branch_id=1&service_id=1&master_id=1&date=2026-02-20",
          "host": ["{{base_url}}"],
          "path": ["api", "slots"],
          "query": [
            {"key": "branch_id", "value": "1"},
            {"key": "service_id", "value": "1"},
            {"key": "master_id", "value": "1"},
            {"key": "date", "value": "2026-02-20"}
          ]
        }
      }
    },
    {
      "name": "Create Appointment",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{base_url}}/api/appointments", "host": ["{{base_url}}"], "path": ["api", "appointments"]},
        "body": {"mode": "raw", "raw": "{\n  \"master_id\": 1,\n  \"branch_id\": 1,\n  \"service_id\": 1,\n  \"start_at\": \"2026-02-20 11:00:00\",\n  \"source\": \"site\"\n}"}
      }
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:8080"},
    {"key": "token", "value": ""}
  ]
}
